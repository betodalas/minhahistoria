# ═══════════════════════════════════════════════════════
# Nossa História — Frontend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════

# URL do backend (local ou Render em produção)
VITE_API_URL=http://localhost:3001/api

# PayPal Client ID (mesmo valor do backend)
VITE_PAYPAL_CLIENT_ID=seu_paypal_client_id

# Google OAuth Client ID (mesmo valor do backend, opcional)
VITE_GOOGLE_CLIENT_ID=seu_google_client_id
