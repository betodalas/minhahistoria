# Banco de dados (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/nossa_historia

# JWT
JWT_SECRET=sua_chave_secreta_muito_longa_aqui

# PayPal
PAYPAL_CLIENT_ID=seu_paypal_client_id
PAYPAL_CLIENT_SECRET=seu_paypal_client_secret
PAYPAL_MODE=sandbox

# Cloudinary (fotos)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# Resend (e-mails transacionais)
RESEND_API_KEY=re_sua_chave_aqui

# App
PORT=3001
API_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PREMIUM_PRICE=49.00

# Admin (protege o endpoint /questions/seed em produção)
# Gere com: openssl rand -hex 32
ADMIN_SECRET=gere_uma_chave_aleatoria_longa_aqui
